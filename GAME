local function hasKnife()
    local char = LocalPlayer.Character
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local function check(item)
        if item:IsA("Tool") then
            local n = string.lower(item.Name)
            if n:find("knife") or n:find("刀") or n == "knife" then return true end
        end
        return false
    end
    if char then for _, item in ipairs(char:GetChildren()) do if check(item) then return true end end end
    if bp then for _, item in ipairs(bp:GetChildren()) do if check(item) then return true end end end
    return false
end

