local function doHeal(root)
    healing = true
    lastLockPos = root.CFrame
    root.CFrame = CFrame.new(Settings.HealPos)
    task.wait()
    root.CFrame = lastLockPos
    root.Velocity = Vector3.new(0, 0, 0)
    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    healing = false
end

local function tpLoop(dt)
    if not Settings.Teleport then resetCamera(); destroyPlatform(); return end
    if fetchingKnife or fetchingAxe or healing then return end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end
    if hum.Health <= 0 then return end

    if Settings.AutoHeal and hum.Health < 100 then
        doHeal(root)
        return
    end

    if Settings.AntiLag then
        local now = tick()
        if now - lastTPTime < 0.08 then return end
        lastTPTime = now
    end
    pcall(function()
        if Settings.AutoKnife and not hasKnife() then
            local dropped = findKnife()
            if dropped then resetCamera(); fetchKnife(); return end
        end
        if Settings.AutoAxe and not hasAxe() then
            local dropped = findAxe()
            if dropped then resetCamera(); fetchAxe(); return end
        end
        if not targetValid(currentTarget) then currentTarget = getNextTarget() end
        if not currentTarget then
            local platform = getPlatform()
            local speedFactor = Settings.PlatformSpeed / 200
            local timer = tick() * speedFactor
            local center = Vector3.new(300000, 15000, 300000)
            local offset = Vector3.new(math.sin(timer) * 1500, 0, math.cos(timer * 0.7) * 1500)
            platform.CFrame = CFrame.new(center + offset)
            root.CFrame = platform.CFrame + Vector3.new(0, 3.5, 0)
            root.Velocity = Vector3.new(0, 0, 0)
            root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            resetCamera()
            return
        end
        local tChar = currentTarget.Character
        local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
        local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
        local cam = Workspace.CurrentCamera
        if tHum and tRoot and cam then
            if Settings.AntiShake then
                if not CameraProxy or not CameraProxy.Parent then
                    CameraProxy = Instance.new("Part")
                    CameraProxy.Name = "CamProxy"
                    CameraProxy.Size = Vector3.new(0.1, 0.1, 0.1)
                    CameraProxy.Transparency = 1
                    CameraProxy.CanCollide = false
                    CameraProxy.CanTouch = false
                    CameraProxy.CanQuery = false
                    CameraProxy.Anchored = true
                    CameraProxy.Parent = Workspace
                    CameraProxy.Position = tRoot.Position
                end
                if (CameraProxy.Position - tRoot.Position).Magnitude > 50 then CameraProxy.Position = tRoot.Position
                else CameraProxy.Position = CameraProxy.Position:Lerp(tRoot.Position, 0.2) end
                cam.CameraSubject = CameraProxy
            else clearCameraProxy(); cam.CameraSubject = tHum end
        else resetCamera() end
        if not tRoot then return end
        local tPos = tRoot.Position
        local tVel = Vector3.new(0, 0, 0)
        pcall(function() tVel = tRoot.AssemblyLinearVelocity or tRoot.Velocity end)
        local lookDir = tRoot.CFrame.LookVector
        local predicted = tPos
        if Settings.Prediction then
            local ping = getPing()
            local clamped = math.clamp(ping, 0.01, 0.35)
            predicted = tPos + (tVel * clamped)
            if math.abs(tVel.Y) > 0.5 then predicted = predicted + Vector3.new(0, tVel.Y * clamped * 1.15, 0) end
        end
        local dest = predicted
        local offDir = Vector3.new(0, 0, 0)
        local step = 3.5
        if Settings.ActionMode == "Front" then
            if tVel.Magnitude > 1.5 then offDir = tVel.Unit else offDir = lookDir end
            dest = predicted + (offDir * step) + Vector3.new(0, 0.4, 0)
        elseif Settings.ActionMode == "Behind" then
            if tVel.Magnitude > 1.5 then offDir = -tVel.Unit else offDir = -lookDir end
            dest = predicted + (offDir * step) + Vector3.new(0, 0.4, 0)
        elseif Settings.ActionMode == "Rotate" then
            local angle = tick() * (Settings.RotateSpeed / 10)
            offDir = Vector3.new(math.cos(angle), 0, math.sin(angle))
            dest = predicted + (offDir * step) + Vector3.new(0, 0.4, 0)
        elseif Settings.ActionMode == "UnderFoot" then
            dest = predicted - Vector3.new(0, 3.2, 0)
        end
        local lookAt = Vector3.new(tPos.X, dest.Y, tPos.Z)
        if (lookAt - dest).Magnitude < 0.01 then lookAt = dest + tRoot.CFrame.LookVector end
        local function getCFrame(pos)
            if Settings.ActionMode == "UnderFoot" then return CFrame.new(pos) * CFrame.Angles(math.rad(90), 0, 0)
            else return CFrame.new(pos, lookAt) end
        end
        if Settings.TPMode == "Instant" then
            root.CFrame = getCFrame(dest)
            root.Velocity = Vector3.new(0, 0, 0)
            root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        else
            local curPos = root.Position
            local dir = (dest - curPos)
            local dist = dir.Magnitude
            if dist > 1 then
                local stepSize = math.min(Settings.SmoothSpeed * (dt * 60), dist)
                if dist > 100 then stepSize = dist * 0.5 end
                local nextPos = curPos + dir.Unit * stepSize
                root.CFrame = getCFrame(nextPos)
                root.Velocity = Vector3.new(0, 0, 0)
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            else
                root.CFrame = getCFrame(dest)
                root.Velocity = Vector3.new(0, 0, 0)
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end
        end
        if Settings.FallProtect then
            local floor = Instance.new("Part")
            floor.Size = Vector3.new(4, 0.2, 4)
            floor.CFrame = CFrame.new(root.Position - Vector3.new(0, 3, 0))
            floor.Anchored = true
            floor.Transparency = 1
            floor.CanCollide = true
            floor.Parent = Workspace
            Debris:AddItem(floor, 0.15)
        end
    end)
end

local function toggleTP(state)
    Settings.Teleport = state
    if state then
        if not tpConnection then tpConnection = RunService.Heartbeat:Connect(tpLoop) end
    else
        if tpConnection then tpConnection:Disconnect(); tpConnection = nil end
        currentTarget = nil
        destroyPlatform()
        resetCamera()
    end
end

