local function getPing()
    local ping = 0.05
    pcall(function() ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    return ping
end

local function matchName(pName, search)
    if not search or search == "" then return false end
    return string.find(string.lower(pName), search, 1, true) ~= nil
end

local function parseList(str)
    local list = {}
    if not str or str == "" then return list end
    for name in string.gmatch(str, "([^,，]+)") do
        local clean = name:gsub("%s+", ""):lower()
        if clean ~= "" then table.insert(list, clean) end
    end
    return list
end

local function updateTargets()
    TargetPatterns = parseList(Settings.TargetNames)
end

local function updateWhitelist()
    WhitelistPatterns = parseList(Settings.Whitelist)
end

local function updateFriends()
    FriendPatterns = parseList(Settings.FriendList)
end

local function isFriend(ply)
    if not ply then return false end
    if ply:IsFriendsWith(LocalPlayer.UserId) then return true end
    for _, p in ipairs(FriendPatterns) do
        if matchName(ply.Name, p) or matchName(ply.DisplayName, p) then return true end
    end
    return false
end

local function isWhitelisted(ply)
    if not ply then return false end
    if isFriend(ply) then return true end
    for _, p in ipairs(WhitelistPatterns) do
        if matchName(ply.Name, p) or matchName(ply.DisplayName, p) then return true end
    end
    return false
end

local function isTarget(ply)
    if not ply or ply == LocalPlayer then return false end
    if isWhitelisted(ply) then return false end
    if Settings.AttackAll then return true end
    if #TargetPatterns == 0 then return false end
    for _, p in ipairs(TargetPatterns) do
        if matchName(ply.Name, p) or matchName(ply.DisplayName, p) then return true end
    end
    return false
end

local function updateAllPlayers()
    local list = {}
    for _, ply in ipairs(Players:GetPlayers()) do
        if ply ~= LocalPlayer then table.insert(list, ply) end
    end
    allPlayers = list
end

local function getValidTargets()
    local valid = {}
    for _, ply in ipairs(allPlayers) do
        if isTarget(ply) then
            local char = ply.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then table.insert(valid, ply) end
        end
    end
    return valid
end

local function targetValid(ply)
    if not ply or not ply.Parent then return false end
    if isWhitelisted(ply) then return false end
    if not isTarget(ply) then return false end
    local char = ply.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then return false end
    return true
end

local function getNextTarget()
    local targets = getValidTargets()
    if #targets == 0 then return nil end
    if currentTarget and targetValid(currentTarget) then return currentTarget end
    rotIndex = rotIndex + 1
    if rotIndex > #targets then rotIndex = 1 end
    return targets[rotIndex]
end

