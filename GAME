end

local function updateAllPlayers()
    local list = {}
    for _, ply in ipairs(Players:GetPlayers()) do
        if ply ~= LocalPlayer then table.insert(list, ply) end
    end
    allPlayers = list
end

local function getPlayerNames()
    local names = {}
    for _, ply in ipairs(allPlayers) do table.insert(names, ply.Name) end
    return names
end

local function isWhitelisted(ply)
    if not ply then return false end
    if Settings.WhitelistNames == "" then return false end
    for _, name in ipairs(parseList(Settings.WhitelistNames)) do
        if ply.Name == name or ply.DisplayName == name then return true end
    end
    return false
end

local function parseList(str)
    local list = {}
    if not str or str == "" then return list end
    for name in string.gmatch(str, "([^,，]+)") do
        local clean = name:gsub("%s+", "")
        if clean ~= "" then table.insert(list, clean) end
    end
    return list
end

local function findPlayerByExactName(name)
    for _, ply in ipairs(Players:GetPlayers()) do
        if ply ~= LocalPlayer then
            if ply.Name == name or ply.DisplayName == name then
                return ply
            end
        end
    end
    return nil
end

local function isTarget(ply)
    if not ply or ply == LocalPlayer then return false end
    if isWhitelisted(ply) then return false end
    if Settings.AttackAll then return true end
    if Settings.TargetNames == "" then return false end
    local targetList = parseList(Settings.TargetNames)
    for _, name in ipairs(targetList) do
        if ply.Name == name or ply.DisplayName == name then return true end
    end
    return false
end

local function getValidTargets()
    local valid = {}
    for _, ply in ipairs(allPlayers) do
        if isTarget(ply) then
            local char = ply.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then table.insert(valid, ply) end
        end
    end
    return valid
end

