local function startDefense()
    if defending then return end
    defending = true
    defenseThread = task.spawn(function()
        pcall(function() VirtualInputManager:SendKeyEvent(true, "R", false, game) end)
        while defending do task.wait(0.5) end
        pcall(function() VirtualInputManager:SendKeyEvent(false, "R", false, game) end)
    end)
end

local function stopDefense()
    defending = false
    if defenseThread then defenseThread = nil end
end

