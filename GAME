local function getClosestForAura()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local lRoot = char.HumanoidRootPart
    local closest, closestDist = nil, Settings.AuraRange
    local function check(obj)
        local tRoot = obj:FindFirstChild("HumanoidRootPart")
        local hum = obj:FindFirstChildOfClass("Humanoid")
        if tRoot and hum and hum.Health > 0 and obj ~= char then
            local dist = (lRoot.Position - tRoot.Position).Magnitude
            if dist <= closestDist then closestDist = dist; closest = obj end
        end
    end
    for _, ply in ipairs(allPlayers) do
        if ply.Character then check(ply.Character) end
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and not Players:GetPlayerFromCharacter(obj) then check(obj) end
    end
    return closest
end

