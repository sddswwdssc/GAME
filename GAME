end

local function ParseVomitMultiList(text)
    local newList = {}
    for name in string.gmatch(text, "([^,]+)") do
        local trimmed = name:match("^%s*(.-)%s*$")
        if trimmed and trimmed ~= "" then table.insert(newList, trimmed) end
    end
    Settings.VomitMultiListTable = newList
    vomitListIndex = 1
end

local function FindPlayerByPartialName(namePart)
    if not namePart or namePart == "" then return nil end
    namePart = string.lower(namePart)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if string.find(string.lower(p.Name), namePart) or string.find(string.lower(p.DisplayName), namePart) then
                return p
            end
        end
    end
    return nil
end

local function FindAndEatSandwich()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local rootPart = char.HumanoidRootPart
    for _, obj in pairs(Workspace:GetDescendants()) do
        if string.lower(obj.Name) == "turkey sandwich" then
            local targetCFrame = nil
            if obj:IsA("Model") and obj.PrimaryPart then targetCFrame = obj.PrimaryPart.CFrame
            elseif obj:IsA("BasePart") then targetCFrame = obj.CFrame
            elseif obj:IsA("Tool") and obj:FindFirstChild("Handle") then targetCFrame = obj.Handle.CFrame
            else local part = obj:FindFirstChildWhichIsA("BasePart", true); if part then targetCFrame = part.CFrame end end
            if targetCFrame then
                rootPart.CFrame = targetCFrame + Vector3.new(0, 1, 0)
                task.wait(0.25)
                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt and fireproximityprompt then fireproximityprompt(prompt) end
                local cd = obj:FindFirstChildWhichIsA("ClickDetector", true)
                if cd and fireclickdetector then fireclickdetector(cd) end
                task.wait(0.35)
                return true
            end
            break
        end
    end
    return false
end

local function GetNextVomitTarget_List()
    if #Settings.VomitMultiListTable == 0 then return nil end
    if vomitListIndex > #Settings.VomitMultiListTable then vomitListIndex = 1 end
    local targetName = Settings.VomitMultiListTable[vomitListIndex]
    vomitListIndex = vomitListIndex + 1
    return FindPlayerByPartialName(targetName)
end

local function GetNextVomitTarget_All()
    local candidates = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(candidates, p)
        end
    end
    if #candidates == 0 then return nil end
    local untargeted = {}
    for _, p in ipairs(candidates) do
        if not vomitTrackingHistory[p.UserId] then table.insert(untargeted, p) end
    end
    if #untargeted == 0 then vomitTrackingHistory = {}; untargeted = candidates end
    local selected = untargeted[1]
    if selected then vomitTrackingHistory[selected.UserId] = true end
    return selected
end

local function VomitStickyLoop(targetPlayer, duration)
    local endTime = tick() + duration
    if targetPlayer.Character and targetPlayer.Character:FindFirstChild("Humanoid") then
        SetCameraSubject(targetPlayer.Character.Humanoid)
    end
    while tick() < endTime and vomitRunning do
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then break end
        local myHum = char.Humanoid
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if not rootPart then break end
        if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
        local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
        local targetHRP = targetPlayer.Character.HumanoidRootPart
        local targetCF = targetHRP.CFrame
        local targetPos = targetHRP.Position
        if targetHum and (targetHum.Jump or targetHum:GetState() == Enum.HumanoidStateType.Jumping) then
            myHum.Jump = true
        end
        if Settings.VomitLagTP and targetHRP.Velocity.Magnitude > 1 then
            local pv = targetHRP.Velocity * 0.25
            targetCF = targetCF + pv
            targetPos = targetPos + pv
        end
        if Settings.VomitActionMode == "Normal" then
            rootPart.CFrame = targetCF
        elseif Settings.VomitActionMode == "Behind" then
            rootPart.CFrame = targetCF * CFrame.new(0, 0, 3)
        elseif Settings.VomitActionMode == "Front" then
            rootPart.CFrame = targetCF * CFrame.new(0, 0, -3) * CFrame.Angles(0, math.rad(180), 0)
        elseif Settings.VomitActionMode == "Rotation" then
            local radius = 4
            local angle = tick() * Settings.VomitRotateSpeed
            local offset = Vector3.new(math.sin(angle) * radius, 0, math.cos(angle) * radius)
            rootPart.CFrame = CFrame.lookAt(targetPos + offset, targetPos)
        elseif Settings.VomitActionMode == "Feet" then
            rootPart.CFrame = (targetCF * CFrame.new(0, -2.5, 0)) * CFrame.Angles(math.rad(90), 0, 0)
        end
        RunService.Heartbeat:Wait()
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        SetCameraSubject(LocalPlayer.Character.Humanoid)
    end
end

local function VomitStartLoop()
    while vomitRunning do
        local char = LocalPlayer.Character
        if not char or not char.Parent or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
            task.wait(1)
            continue
        end
        local hum = char.Humanoid
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if not rootPart then task.wait(0.5); continue end
        SetCameraSubject(hum)
        Teleport(CFrame.new(Settings.HealPos))
        task.wait(0.2)
        while hum.Health < hum.MaxHealth and vomitRunning and hum.Health > 0 do
            rootPart.CFrame = CFrame.new(Settings.HealPos)
            task.wait(0.1)
        end
        if hum.Health <= 0 or not vomitRunning then continue end
        local eatSuccess = FindAndEatSandwich()
        if not eatSuccess then task.wait(0.5); continue end
        if vomitRunning then task.wait(Settings.VomitAfterEat) end
        if hum.Health <= 0 or not vomitRunning then continue end
        local targetPlayer = nil
        if Settings.VomitLoopList then targetPlayer = GetNextVomitTarget_List()
        elseif Settings.VomitLoopAll then targetPlayer = GetNextVomitTarget_All() end
        if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            Teleport(targetPlayer.Character.HumanoidRootPart.CFrame)
            VomitStickyLoop(targetPlayer, Settings.VomitStayTime)
        else
            task.wait(1)
        end
        task.wait(0.1)
    end
end

